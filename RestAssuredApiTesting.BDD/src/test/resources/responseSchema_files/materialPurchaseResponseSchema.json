{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Material Purchase Response",
  "type": "object",
  "additionalProperties": true,

  "required": [
    "remark",
    "purchase_date",
    "vendor_reference_number",
    "party_company_user_id",
    "project_id",
    "material_amount",
    "gst_amount",
    "other_amount",
    "discount",
    "total_payable",
    "net_amount",
    "company_id",
    "created",
    "id"
  ],

  "properties": {
    "id": { "type": "string" },
    "company_id": { "type": "string" },
    "creator_company_user_id": { "type": ["string", "null"] },

    "remark": { "type": "string" },
    "purchase_date": { "type": "string" },
    "vendor_reference_number": { "type": "string" },

    "party_company_user_id": { "type": "string" },
    "project_id": { "type": "string" },

    "sub_category_id": { "type": ["string", "null"] },
    "invoice_id": { "type": ["string", "null"] },

    "material_ids": {
      "type": "array",
      "items": { "type": "string" }
    },

    "material_amount": { "type": "number" },
    "gst_amount": { "type": "number" },
    "other_amount": { "type": "number" },
    "discount": { "type": "number" },
    "total_payable": { "type": "number" },
    "net_amount": { "type": "number" },

    "sequence": { "type": ["integer", "null"] },

    "photos": {
      "type": "array",
      "items": { "type": "string" }
    },

    "delete": { "type": ["integer", "null"] },

    "created": { "type": "string" },
    "updated": { "type": ["string", "null"] },

    "approval_flag": { "type": ["string", "null"] },
    "approval_comment": { "type": ["string", "null"] },
    "approved_by": { "type": ["string", "null"] },

    "monkey_patch_materials": {
      "type": ["array", "null"]
    },

    "monkey_patch_is_editable": { "type": ["integer", "null"] },
    "monkey_patch_paid_amount": { "type": ["number", "null"] },

    "due_days": { "type": ["integer", "null"] },

    "ship_to_address_id": { "type": ["string", "null"] },
    "bill_to_address_id": { "type": ["string", "null"] },
    "ship_from_address_id": { "type": ["string", "null"] },
    "bill_from_address_id": { "type": ["string", "null"] },

    "due_date": { "type": ["string", "null"] },

    "pre_tax_deduction_amount": { "type": ["number", "null"] },
    "post_tax_deduction_amount": { "type": ["number", "null"] },
    "deduction_amount": { "type": ["number", "null"] },

    "is_roundoff": { "type": ["integer", "null"] },

    "other_amount_gst_percentage": { "type": ["number", "null"] },
    "other_amount_gst_amount": { "type": ["number", "null"] },
    "other_amount_text": { "type": ["string", "null"] },

    "meta_data": {
      "type": ["object", "null"],
      "properties": {
        "can_edit": { "type": ["integer", "null"] },
        "can_update_approval_flag": { "type": ["integer", "null"] }
      }
    }
  }
}