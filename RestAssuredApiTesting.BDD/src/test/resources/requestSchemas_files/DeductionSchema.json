{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Deduction Item Request Schema",
  "type": "object",
  "required": [
    "feature_id",
    "feature_type",
    "project_id",
    "deduction_entry_data",
    "amount"
  ],
  "properties": {
    "feature_id": {
      "type": "string"
    },
    "feature_type": {
      "type": "string"
    },
    "project_id": {
      "type": "string"
    },
    "amount": {
      "type": "number"
    },
    "deduction_entry_data": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "deduction_item_id",
          "project_id",
          "amount",
          "pre_tax"
        ],
        "properties": {
          "deduction_item_id": {
            "type": "string"
          },
          "salesorder_invoice_id": {
            "type": ["string", "null"]
          },
          "project_id": {
            "type": "string"
          },
          "amount": {
            "type": "number"
          },
          "pre_tax": {
            "type": "number"
          }
        }
      }
    }
  }
}