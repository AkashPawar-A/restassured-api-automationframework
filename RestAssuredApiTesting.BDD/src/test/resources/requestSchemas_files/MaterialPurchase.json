{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title" : "Material Purchase",
  "type": "object",
  "additionalProperties": false,

  "required": [
    "remark",
    "purchase_date",
    "vendor_reference_number",
    "party_company_user_id",
    "project_id",
    "material_amount",
    "gst_amount",
    "other_amount",
    "discount",
    "total_payable",
    "net_amount",
    "materials"
  ],

  "properties": {
    "remark": { "type": "string" },
    "purchase_date": { "type": "string", "format": "date-time" },
    "vendor_reference_number": { "type": "string" },
    "party_company_user_id": { "type": "string", "format": "uuid" },
    "project_id": { "type": "string", "format": "uuid" },
    "sub_category_id": { "type": ["string", "null"], "format": "uuid" },
    "due_days": { "type": ["integer", "null"] },
    "ship_to_address_id": { "type": ["string", "null"], "format": "uuid" },
    "bill_to_address_id": { "type": ["string", "null"], "format": "uuid" },
    "ship_from_address_id": { "type": ["string", "null"], "format": "uuid" },
    "bill_from_address_id": { "type": ["string", "null"], "format": "uuid" },
    "material_amount": { "type": "number" },
    "gst_amount": { "type": "number" },
    "other_amount": { "type": "number" },
    "discount": { "type": "number" },
    "total_payable": { "type": "number" },
    "net_amount": { "type": "number" },
    "is_roundoff": { "type": ["integer", "null"] },
    "other_amount_gst_percentage": { "type": ["number", "null"] },
    "other_amount_gst_amount": { "type": ["number", "null"] },
    "other_amount_text": { "type": ["string", "null"] },
    "photos": { "type": "array", "items": { "type": "string" } },
    
    "materials": { "type": "array", "minItems": 1,
      "items": { "type": "object", "additionalProperties": false,
        "required": [
          "material_item_id",
          "materialstock_id",
          "type",
          "name",
          "quantity",
          "unit",
          "unit_price",
          "gst_percent",
          "gst_amount",
          "discount_amount",
          "total_payable",
          "receiving_date",
          "is_purchase",
          "photos"
        ],

        "properties": {
          "material_item_id": { "type": "string", "format": "uuid" },
          "materialstock_id": { "type": "string", "format": "uuid" },
          "type": { "type": "string" },
          "name": { "type": "string" },
          "quantity": { "type": "number" },
          "unit": { "type": "string" },
          "unit_price": { "type": "number" },
          "gst_percent": { "type": "number" },
          "gst_amount": { "type": "number" },
          "discount_amount": { "type": "number" },
          "total_payable": { "type": "number" },
          "receiving_date": { "type": "string", "format": "date-time" },
          "is_purchase": { "type": "integer" },
          "is_material_returned": { "type": ["integer", "null"] },
          "is_material_sold": { "type": ["integer", "null"] },
          "notes": { "type": ["string", "null"] },
          "hsn_code": { "type": ["string", "null"] },
          "item_code": { "type": ["string", "null"] },
          "photos": { "type": "array", "items": { "type": "string" }
          }
        }
      }
    }
  }
}
